# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Note: SUPABASE_SERVICE_ROLE_KEY should only be used on the server.
# For client-side (if needed), use VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY.

# VPS Bridge
VPS_SSH_HOST=168.231.78.113
VPS_SSH_PORT=22
VPS_SSH_USER=root
VPS_SSH_PASSWORD=
VPS_SSH_HOST_FINGERPRINT=
VPS_SANDBOX_DIR=/tmp/eburon-vcall-sandbox
VPS_ALLOW_SYSTEM_COMMANDS=false
VPS_OLLAMA_SELF_URL=http://127.0.0.1:11434
# Use the same URL when Ollama cloud models are pulled into the local VPS Ollama instance.
VPS_OLLAMA_CLOUD_URL=
VPS_OLLAMA_DEFAULT_MODEL=
# Optional: exact remote Hermes command that reads prompt text from stdin.
VPS_HERMES_COMMAND=

# Firebase (used by both client and server)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
FIREBASE_PROJECT_ID=

# Gemini API Key
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=
